# ═══════════════════════════════════════════════════════════════════════════════
# GeoLogix AI v2.0 - Environment Configuration
# Copy this file to .env and customize for your deployment
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# SERVER SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=true

# ─────────────────────────────────────────────────────────────────────────────────
# AI PROVIDER (Primary)
# Options: "ollama" or "lmstudio"
# ─────────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama

# Ollama Settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_TIMEOUT=120

# LM Studio Settings (fallback)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=llama-3.1-8b-instruct

# ─────────────────────────────────────────────────────────────────────────────────
# AI PARAMETERS
# ─────────────────────────────────────────────────────────────────────────────────
CONTEXT_WINDOW=8192
MAX_TOKENS=4096
TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────────────────────────
# FEATURES (Enable/Disable)
# ─────────────────────────────────────────────────────────────────────────────────
ENABLE_WEB_SEARCH=true
ENABLE_DEEP_THINKING=true
ENABLE_CHAT_HISTORY=true
ENABLE_FORECASTING=true

# ─────────────────────────────────────────────────────────────────────────────────
# WEB SEARCH SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=10

# ─────────────────────────────────────────────────────────────────────────────────
# CHAT HISTORY SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────
CHAT_HISTORY_LIMIT=100
CHAT_CONTEXT_MESSAGES=10

# ─────────────────────────────────────────────────────────────────────────────────
# SECURITY (Change in production!)
# ─────────────────────────────────────────────────────────────────────────────────
SECRET_KEY=geologix-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────────
# NGROK (Remote Access)
# ─────────────────────────────────────────────────────────────────────────────────
NGROK_ENABLED=false
NGROK_DOMAIN=geologix.ngrok.io

# ─────────────────────────────────────────────────────────────────────────────────
# LOGGING
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ─────────────────────────────────────────────────────────────────────────────────
# DATA PATHS (Relative to backend root)
# ─────────────────────────────────────────────────────────────────────────────────
DATA_DIR=Data_Directories
ARCHIVE_INDEX=archive_index.json
COMPANY_INDEX=company_index.json
EMAIL_INDEX=email_index.json
CHAT_DIR=chats
